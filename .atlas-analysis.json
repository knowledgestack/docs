  "keyFeatures": [
    "Document ingestion and version management",
    "Semantic chunk search with vector embeddings",
    "Conversational threads with AI streaming",
    "Multi-tenant workspace isolation",
    "Role-based access control and group permissions",
    "Custom workflow definitions and runs",
    "SSO and directory sync support",
    "Tag-based and path-based content organization"
  ],
  "publicApiSurface": [
    "POST /v1/auth/pw/signin",
    "POST /v1/auth/sso/initiate",
    "POST /v1/documents/ingest",
    "GET /v1/documents",
    "GET /v1/documents/{document_id}",
    "POST /v1/documents/{document_id}/versions",
    "POST /v1/chunks/search",
    "GET /v1/chunks/{chunk_id}",
    "POST /v1/threads",
    "POST /v1/threads/{thread_id}/user_message",
    "GET /v1/threads/{thread_id}/stream",
    "GET /v1/folders",
    "POST /v1/folders",
    "GET /v1/tenants",
    "POST /v1/tenants/{tenant_id}/users/{user_id}/activate",
    "POST /v1/api-keys",
    "GET /v1/api-keys",
    "POST /v1/workflow-definitions",
    "POST /v1/workflow-definitions/{definition_id}/invoke",
    "GET /v1/tags",
    "POST /v1/invites",
    "GET /v1/user-permissions"
  ]
}
